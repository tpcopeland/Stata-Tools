. do test_gcomptab.do 

. /****************************************************************************
> ***
> * test_gcomptab.do
> *
> * Purpose: Comprehensive testing of gcomptab command
> *          Tests all options with simulated gcomp results
> *
> * Note: Since gcomp is an external SSC package that may not be installed,
> *       this test file uses a mock helper program that simulates gcomp's
> *       r() output structure. This allows testing gcomptab's formatting
> *       functionality without requiring gcomp to be installed.
> *
> * Prerequisites:
> *   - gcomptab.ado must be installed/accessible
> *   - Stata 16+ required
> *
> * Author: Timothy P Copeland
> * Date: 2025-12-19
> *****************************************************************************
> **/
. 
. clear all

. set more off

. version 16.0

. 
. * ===========================================================================
> ==
. * PATH CONFIGURATION
. * ===========================================================================
> ==
. * Detect Stata-Tools repo root
. capture confirm file "gcomp/gcomptab.ado"

. if _rc == 0 {
.     * Running from Stata-Tools root
.     global STATA_TOOLS_PATH "`c(pwd)'"
. }

. else {
.     capture confirm file "../../gcomp/gcomptab.ado"
.     if _rc == 0 {
.         * Running from gcomp/qa/ directory
.         global STATA_TOOLS_PATH "`c(pwd)'/../.."
.     }
.     else {
.         global STATA_TOOLS_PATH "/home/`c(username)'/Stata-Tools"
.     }
. }

. 
. * Add gcomp package to adopath
. adopath ++ "${STATA_TOOLS_PATH}/gcomp"
  [1]              "/home/tpcopeland/Stata-Tools/gcomp/qa/../../gcomp"
  [2]  (BASE)      "/usr/local/stata17/ado/base/"
  [3]  (SITE)      "/usr/local/ado/"
  [4]              "."
  [5]  (PERSONAL)  "~/ado/personal/"
  [6]  (PLUS)      "~/ado/plus/"
  [7]  (OLDPLACE)  "~/ado/"

. 
. * Test output directory
. local testdir "`c(tmpdir)'"

. 
. display as text _n "{hline 70}"

----------------------------------------------------------------------

. display as text "GFORMTAB COMMAND TESTING"
GFORMTAB COMMAND TESTING

. display as text "{hline 70}"
----------------------------------------------------------------------

. display as text "Test directory: `testdir'"
Test directory: /tmp

. display as text "{hline 70}"
----------------------------------------------------------------------

. 
. local test_count = 0

. local pass_count = 0

. local fail_count = 0

. 
. * ===========================================================================
> ==
. * HELPER: Mock gcomp output
. * ===========================================================================
> ==
. * This program simulates the r() scalars and matrices that gcomp produces
. * so we can test gcomptab without requiring gcomp to be installed.
. 
. capture program drop mock_gcomp

. program define mock_gcomp, eclass
  1.     version 16.0
  2.     syntax, tce(real) nde(real) nie(real) pm(real) cde(real) ///
>             [se_tce(real 0.05) se_nde(real 0.04) se_nie(real 0.03) ///
>              se_pm(real 0.02) se_cde(real 0.04)]
  3. 
.     * Build b vector and V matrix
.     tempname b V se_mat
  4.     matrix `b' = (`tce', `nde', `nie', `pm', `cde')
  5.     matrix colnames `b' = tce nde nie pm cde
  6.     matrix `V' = J(5, 5, 0)
  7.     matrix `V'[1,1] = `se_tce'^2
  8.     matrix `V'[2,2] = `se_nde'^2
  9.     matrix `V'[3,3] = `se_nie'^2
 10.     matrix `V'[4,4] = `se_pm'^2
 11.     matrix `V'[5,5] = `se_cde'^2
 12.     matrix colnames `V' = tce nde nie pm cde
 13.     matrix rownames `V' = tce nde nie pm cde
 14. 
.     * Post to e()
.     ereturn post `b' `V'
 15.     ereturn local cmd "gcomp"
 16.     ereturn local analysis_type "mediation"
 17. 
.     * Convenience scalars
.     ereturn scalar tce = `tce'
 18.     ereturn scalar nde = `nde'
 19.     ereturn scalar nie = `nie'
 20.     ereturn scalar pm = `pm'
 21.     ereturn scalar cde = `cde'
 22.     ereturn scalar se_tce = `se_tce'
 23.     ereturn scalar se_nde = `se_nde'
 24.     ereturn scalar se_nie = `se_nie'
 25.     ereturn scalar se_pm = `se_pm'
 26.     ereturn scalar se_cde = `se_cde'
 27. 
.     * SE vector
.     matrix `se_mat' = (`se_tce', `se_nde', `se_nie', `se_pm', `se_cde')
 28.     matrix colnames `se_mat' = tce nde nie pm cde
 29.     ereturn matrix se = `se_mat'
 30. 
.     * Create CI matrices matching real gcomp layout: 2 rows x 5 cols
.     * Row 1 = lower bounds, Row 2 = upper bounds
.     * Cols named: tce nde nie pm cde
.     tempname cin cip cibc cibca
 31.     matrix `cin' = J(2, 5, .)
 32.     matrix `cin'[1,1] = `tce' - 1.96*`se_tce'
 33.     matrix `cin'[2,1] = `tce' + 1.96*`se_tce'
 34.     matrix `cin'[1,2] = `nde' - 1.96*`se_nde'
 35.     matrix `cin'[2,2] = `nde' + 1.96*`se_nde'
 36.     matrix `cin'[1,3] = `nie' - 1.96*`se_nie'
 37.     matrix `cin'[2,3] = `nie' + 1.96*`se_nie'
 38.     matrix `cin'[1,4] = `pm' - 1.96*`se_pm'
 39.     matrix `cin'[2,4] = `pm' + 1.96*`se_pm'
 40.     matrix `cin'[1,5] = `cde' - 1.96*`se_cde'
 41.     matrix `cin'[2,5] = `cde' + 1.96*`se_cde'
 42.     matrix colnames `cin' = tce nde nie pm cde
 43.     ereturn matrix ci_normal = `cin'
 44. 
.     * Create percentile CI (slightly different for testing)
.     matrix `cip' = J(2, 5, .)
 45.     matrix `cip'[1,1] = `tce' - 2.0*`se_tce'
 46.     matrix `cip'[2,1] = `tce' + 1.9*`se_tce'
 47.     matrix `cip'[1,2] = `nde' - 2.0*`se_nde'
 48.     matrix `cip'[2,2] = `nde' + 1.9*`se_nde'
 49.     matrix `cip'[1,3] = `nie' - 2.0*`se_nie'
 50.     matrix `cip'[2,3] = `nie' + 1.9*`se_nie'
 51.     matrix `cip'[1,4] = `pm' - 2.0*`se_pm'
 52.     matrix `cip'[2,4] = `pm' + 1.9*`se_pm'
 53.     matrix `cip'[1,5] = `cde' - 2.0*`se_cde'
 54.     matrix `cip'[2,5] = `cde' + 1.9*`se_cde'
 55.     matrix colnames `cip' = tce nde nie pm cde
 56.     ereturn matrix ci_percentile = `cip'
 57. 
.     * Create bias-corrected CI
.     matrix `cibc' = J(2, 5, .)
 58.     matrix `cibc'[1,1] = `tce' - 2.05*`se_tce'
 59.     matrix `cibc'[2,1] = `tce' + 1.85*`se_tce'
 60.     matrix `cibc'[1,2] = `nde' - 2.05*`se_nde'
 61.     matrix `cibc'[2,2] = `nde' + 1.85*`se_nde'
 62.     matrix `cibc'[1,3] = `nie' - 2.05*`se_nie'
 63.     matrix `cibc'[2,3] = `nie' + 1.85*`se_nie'
 64.     matrix `cibc'[1,4] = `pm' - 2.05*`se_pm'
 65.     matrix `cibc'[2,4] = `pm' + 1.85*`se_pm'
 66.     matrix `cibc'[1,5] = `cde' - 2.05*`se_cde'
 67.     matrix `cibc'[2,5] = `cde' + 1.85*`se_cde'
 68.     matrix colnames `cibc' = tce nde nie pm cde
 69.     ereturn matrix ci_bc = `cibc'
 70. 
.     * Create BCa CI
.     matrix `cibca' = J(2, 5, .)
 71.     matrix `cibca'[1,1] = `tce' - 2.1*`se_tce'
 72.     matrix `cibca'[2,1] = `tce' + 1.8*`se_tce'
 73.     matrix `cibca'[1,2] = `nde' - 2.1*`se_nde'
 74.     matrix `cibca'[2,2] = `nde' + 1.8*`se_nde'
 75.     matrix `cibca'[1,3] = `nie' - 2.1*`se_nie'
 76.     matrix `cibca'[2,3] = `nie' + 1.8*`se_nie'
 77.     matrix `cibca'[1,4] = `pm' - 2.1*`se_pm'
 78.     matrix `cibca'[2,4] = `pm' + 1.8*`se_pm'
 79.     matrix `cibca'[1,5] = `cde' - 2.1*`se_cde'
 80.     matrix `cibca'[2,5] = `cde' + 1.8*`se_cde'
 81.     matrix colnames `cibca' = tce nde nie pm cde
 82.     ereturn matrix ci_bca = `cibca'
 83. 
. end

. 
. * ===========================================================================
> ==
. * TEST 1: Basic gcomptab with simulated results
. * ===========================================================================
> ==
. local ++test_count

. display as text _n "TEST `test_count': Basic gcomptab"

TEST 1: Basic gcomptab

. display as text "{hline 50}"
--------------------------------------------------

. 
. capture noisily {
.     * Simulate typical mediation analysis results
.     * TCE = 0.15 (total effect of treatment on outcome)
.     * NDE = 0.10 (direct effect)
.     * NIE = 0.05 (indirect effect via mediator)
.     * PM = 0.33 (proportion mediated = NIE/TCE)
.     * CDE = 0.08 (controlled direct effect)
. 
.     mock_gcomp, tce(0.15) nde(0.10) nie(0.05) pm(0.33) cde(0.08) ///
>         se_tce(0.03) se_nde(0.025) se_nie(0.015) se_pm(0.08) se_cde(0.025)
. 
.     gcomptab, xlsx("`testdir'/_test_gcomptab.xlsx") sheet("Mediation")
. 
.     confirm file "`testdir'/_test_gcomptab.xlsx"
.     display as result "  PASSED: Basic gcomptab works"
  PASSED: Basic gcomptab works
.     local ++pass_count
. }

. if _rc {
.     display as error "  FAILED: Error code " _rc
.     local ++fail_count
. }

