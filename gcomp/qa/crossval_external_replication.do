else {
    display as error "  FAIL: external continuous-outcome time-varying replication (error `=_rc')"
    local ++fail_count
    local failed_tests "`failed_tests' timevarying_continuous"
}

capture program drop _external_compare

display as text ""
display as result "External replication results: `pass_count'/`test_count' passed, `fail_count' failed"
if `fail_count' > 0 {
    display "RESULT: crossval_external_replication tests=`test_count' pass=`pass_count' fail=`fail_count' status=FAIL"
    display as error "FAIL"
    display as error "Failed scenarios:`failed_tests'"
    exit 1
}
display "RESULT: crossval_external_replication tests=`test_count' pass=`pass_count' fail=`fail_count' status=PASS"
display as result "PASS"
