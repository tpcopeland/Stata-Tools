* crossval_external_replication.do - external Python replication for gcomp
* Manual run from this qa/ directory: stata-mp -b do crossval_external_replication.do
* Fixtures: qa/data/external_*.csv generated by qa/data/generate_external_replication.py

clear all
version 16.0

local test_count = 0
local pass_count = 0
local fail_count = 0
local failed_tests ""

local qa_dir "`c(pwd)'"
local pkg_dir = subinstr("`qa_dir'", "/qa", "", 1)

capture ado uninstall gcomp
quietly net install gcomp, from("`pkg_dir'") replace
discard

preserve
import delimited using "`qa_dir'/data/external_reference.csv", clear varnames(1) asdouble
forvalues i = 1/`=_N' {
    local analysis = analysis[`i']
    local metric = metric[`i']
    if "`analysis'" == "mediation_binary" local key "mb"
    else if "`analysis'" == "mediation_continuous" local key "mc"
    else if "`analysis'" == "timevarying_binary" local key "tvb"
    else if "`analysis'" == "timevarying_continuous" local key "tvc"
    local ref_`key'_`metric' = value[`i']
    local tol_`key'_`metric' = tolerance[`i']
}
restore

capture program drop _external_compare
program define _external_compare
    version 16.0
    syntax, ACTual(real) EXpected(real) TOLerance(real) LABEL(string)

    local diff = abs(`actual' - `expected')
    noisily display as text "    `label': Stata=" %12.9f `actual' ///
        " Python=" %12.9f `expected' " diff=" %10.8f `diff' ///
        " tol=" %10.8f `tolerance'
    assert `diff' <= `tolerance'
end

**# Mediation: binary mediator and binary outcome
local ++test_count
capture noisily {
    import delimited using "`qa_dir'/data/external_mediation_binary.csv", clear asdouble

    gcomp y m x c, outcome(y) mediation obe ///
        exposure(x) mediator(m) base_confs(c) control(0) ///
        commands(m: logit, y: logit) ///
        equations(m: x c, y: m x c) ///
        sim(5000) samples(5) seed(20260506) minsim moreMC

    assert "`e(cmd)'" == "gcomp"
    assert "`e(analysis_type)'" == "mediation"
    assert "`e(mediation_type)'" == "obe"
    assert "`e(scale)'" == "RD"

    local gc_tce = e(tce)
    local gc_nde = e(nde)
    local gc_nie = e(nie)
    local gc_pm = e(pm)
    local gc_cde = e(cde)

    _external_compare, actual(`gc_tce') expected(`ref_mb_tce') ///
        tolerance(`tol_mb_tce') label("binary mediation TCE")
    _external_compare, actual(`gc_nde') expected(`ref_mb_nde') ///
        tolerance(`tol_mb_nde') label("binary mediation NDE")
    _external_compare, actual(`gc_nie') expected(`ref_mb_nie') ///
        tolerance(`tol_mb_nie') label("binary mediation NIE")
    _external_compare, actual(`gc_pm') expected(`ref_mb_pm') ///
        tolerance(`tol_mb_pm') label("binary mediation PM")
    _external_compare, actual(`gc_cde') expected(`ref_mb_cde') ///
        tolerance(`tol_mb_cde') label("binary mediation CDE")
}
if _rc == 0 {
    display as result "  PASS: external binary-outcome mediation replication"
    local ++pass_count
}
else {
    display as error "  FAIL: external binary-outcome mediation replication (error `=_rc')"
    local ++fail_count
    local failed_tests "`failed_tests' mediation_binary"
}

