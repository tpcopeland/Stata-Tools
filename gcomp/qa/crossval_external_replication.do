**# Time-varying g-computation: binary end-of-follow-up outcome
local ++test_count
capture noisily {
    import delimited using "`qa_dir'/data/external_timevarying.csv", clear asdouble

    gcomp y l0 a l alag llag id time, outcome(y) ///
        idvar(id) tvar(time) ///
        varyingcovariates(l) fixedcovariates(l0) ///
        laggedvars(alag llag) ///
        lagrules(alag: a 1, llag: l 1) ///
        intvars(a) interventions(a=1, a=0) eofu ///
        commands(a: logit, y: logit, l: regress) ///
        equations(a: l0 l, y: alag llag l0, l: alag llag l0) ///
        sim(450) samples(5) seed(20260508) minsim

    assert "`e(cmd)'" == "gcomp"
    assert "`e(analysis_type)'" == "time_varying"

    tempname b
    matrix `b' = e(b)
    local po_a1 = `b'[1, colnumb(`b', "PO1")]
    local po_a0 = `b'[1, colnumb(`b', "PO2")]
    local rd = `po_a1' - `po_a0'

    _external_compare, actual(`po_a1') expected(`ref_tvb_po_a1') ///
        tolerance(`tol_tvb_po_a1') label("time-varying binary PO A=1")
    _external_compare, actual(`po_a0') expected(`ref_tvb_po_a0') ///
        tolerance(`tol_tvb_po_a0') label("time-varying binary PO A=0")
    _external_compare, actual(`rd') expected(`ref_tvb_rd_a1_a0') ///
        tolerance(`tol_tvb_rd_a1_a0') label("time-varying binary RD")
}
if _rc == 0 {
    display as result "  PASS: external binary-outcome time-varying replication"
    local ++pass_count
}
else {
    display as error "  FAIL: external binary-outcome time-varying replication (error `=_rc')"
    local ++fail_count
    local failed_tests "`failed_tests' timevarying_binary"
}

**# Time-varying g-computation: continuous end-of-follow-up outcome
local ++test_count
capture noisily {
    import delimited using "`qa_dir'/data/external_timevarying.csv", clear asdouble

    gcomp yc l0 a l alag llag id time, outcome(yc) ///
        idvar(id) tvar(time) ///
        varyingcovariates(l) fixedcovariates(l0) ///
        laggedvars(alag llag) ///
        lagrules(alag: a 1, llag: l 1) ///
        intvars(a) interventions(a=1, a=0) eofu ///
        commands(a: logit, yc: regress, l: regress) ///
        equations(a: l0 l, yc: alag llag l0, l: alag llag l0) ///
        sim(450) samples(5) seed(20260508) minsim

    assert "`e(cmd)'" == "gcomp"
    assert "`e(analysis_type)'" == "time_varying"

    tempname b
    matrix `b' = e(b)
    local po_a1 = `b'[1, colnumb(`b', "PO1")]
    local po_a0 = `b'[1, colnumb(`b', "PO2")]
    local rd = `po_a1' - `po_a0'

    _external_compare, actual(`po_a1') expected(`ref_tvc_po_a1') ///
        tolerance(`tol_tvc_po_a1') label("time-varying continuous PO A=1")
    _external_compare, actual(`po_a0') expected(`ref_tvc_po_a0') ///
        tolerance(`tol_tvc_po_a0') label("time-varying continuous PO A=0")
    _external_compare, actual(`rd') expected(`ref_tvc_rd_a1_a0') ///
        tolerance(`tol_tvc_rd_a1_a0') label("time-varying continuous RD")
