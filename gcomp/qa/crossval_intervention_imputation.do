capture program drop _iix_compare
capture program drop _iix_extract_stochastic
capture program drop _iix_extract_dynamic
capture program drop _iix_extract_mediation

display as text ""
display as result "Intervention/imputation cross-validation: `pass_count'/`test_count' passed, `fail_count' failed"
if `fail_count' > 0 {
    display "RESULT: crossval_intervention_imputation tests=`test_count' pass=`pass_count' fail=`fail_count' status=FAIL"
    display as error "FAIL"
    display as error "Failed comparisons:`failed_tests'"
    exit 1
}

display "RESULT: crossval_intervention_imputation tests=`test_count' pass=`pass_count' fail=`fail_count' status=PASS"
display as result "PASS"
