**# Imputation path
import delimited using "`data_dir'/intervention_imputation_mediation_data.csv", clear varnames(1) asdouble
quietly count
local nmed = r(N)

gcomp y m x c z, outcome(y) mediation obe ///
    exposure(x) mediator(m) base_confs(c) control(0) ///
    commands(m: regress, y: regress) ///
    equations(m: x c, y: m x c) ///
    impute(m) imp_cmd(m: regress) imp_eq(m: x c z) imp_cycles(2) ///
    sim(4000) samples(`stata_boot_reps') seed(20260526) minsim moreMC

_iix_extract_mediation

foreach metric in tce nde nie pm cde {
    local a_imp_`metric' = r(`metric')
    local a_imp_se_`metric' = r(se_`metric')
    local a_imp_vd_`metric' = r(vdiag_`metric')
}
local a_imp_cov_tce_nde = r(cov_tce_nde)
