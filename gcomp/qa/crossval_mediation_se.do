postclose `pf'

use `checks', clear
gen double diff = abs(actual - expected)
gen byte passed = .
replace passed = (diff <= tolerance) if op == "abs"
replace passed = (actual == expected) if op == "eq"
replace passed = (abs(actual) > tolerance) if op == "gtabs"

local test_count = _N
quietly count if passed == 1
local pass_count = r(N)
quietly count if passed != 1
local fail_count = r(N)

forvalues i = 1/`=_N' {
    if passed[`i'] == 1 {
        if op[`i'] == "gtabs" {
            display as result "  PASS: " label[`i'] " offdiag=" %10.8f actual[`i'] " min=" %10.8f tolerance[`i']
        }
        else {
            display as result "  PASS: " label[`i'] " actual=" %12.8f actual[`i'] ///
                " expected=" %12.8f expected[`i'] " diff=" %10.8f diff[`i'] ///
                " tol=" %10.8f tolerance[`i']
        }
    }
    else {
        if op[`i'] == "gtabs" {
            display as error "  FAIL: " label[`i'] " offdiag=" %10.8f actual[`i'] " min=" %10.8f tolerance[`i']
        }
        else {
            display as error "  FAIL: " label[`i'] " actual=" %12.8f actual[`i'] ///
                " expected=" %12.8f expected[`i'] " diff=" %10.8f diff[`i'] ///
                " tol=" %10.8f tolerance[`i']
        }
    }
}

display as text ""
display as result "Mediation SE cross-validation results: `pass_count'/`test_count' passed, `fail_count' failed"
if `fail_count' > 0 {
    display "RESULT: crossval_mediation_se tests=`test_count' pass=`pass_count' fail=`fail_count' status=FAIL"
    exit 1
}
display "RESULT: crossval_mediation_se tests=`test_count' pass=`pass_count' fail=`fail_count' status=PASS"
