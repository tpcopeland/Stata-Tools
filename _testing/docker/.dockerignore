# Docker ignore file for Stata-MCP testing environment

# Git
.git
.gitignore

# Documentation
*.md
!README.md

# IDE
.vscode
.idea
*.code-workspace

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.log
*.bak

# Python
__pycache__
*.pyc
*.pyo
.pytest_cache
.mypy_cache
*.egg-info

# Node
node_modules

# Test output (will be volume-mounted)
test-output/

# Sensitive files
.env
*.key
*.pem
credentials*
