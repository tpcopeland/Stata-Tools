# Environment variables for Stata-MCP Testing Docker Setup
# Copy this file to .env and fill in your paths

# REQUIRED: Path to your Stata-MCP server installation
# This is the directory containing the MCP server that interfaces with Stata
STATA_MCP_PATH=/path/to/your/Stata-MCP

# OPTIONAL: Path to Stata executable (if not using default MCP configuration)
# Leave empty if Stata-MCP handles this automatically
STATA_PATH=

# OPTIONAL: Path to Stata-Tools repository
# Default: parent directory (../..)
# STATA_TOOLS_PATH=/path/to/Stata-Tools
