# Docker Environment Configuration
# Copy this file to .env and update the paths

# Path to your Stata Linux installation (REQUIRED)
# This directory should contain: stata-mp (or stata-se), stata.lic, ado/, etc.
# Store OUTSIDE your repos - reusable across projects
#
# IMPORTANT: You need Stata for Linux, not macOS Stata.
# Download from: https://www.stata.com/customer-service/ > Download Stata > Unix/Linux
STATA_PATH=/Users/yourusername/stata18-linux

# Stata version (optional, for display purposes)
# Set to your Stata version: 17, 18, etc.
STATA_VERSION=18

# Path to your working directory (defaults to Stata-Tools repo)
WORK_DIR=../..
