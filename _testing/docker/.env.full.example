# Full Sandbox Environment Configuration
# Copy this to .env.full and fill in your paths

# Path to Stata-Tools repository
STATA_TOOLS_PATH=../..

# Path to Stata for LINUX installation
# You need the Linux version of Stata, not macOS
# Option 1: If you have Linux Stata installed somewhere
STATA_LINUX_PATH=/path/to/stata17-linux

# Option 2: Download Linux Stata and extract it
# See: https://www.stata.com/support/faqs/unix/install-download/
# STATA_LINUX_PATH=./stata17

# Path to Stata-MCP server (from your VS Code extension)
# Copy the src directory from the extension
STATA_MCP_PATH=/Users/tcopeland/.vscode/extensions/deepecon.stata-mcp-0.3.6/src

# Stata edition (mp, se, or be)
STATA_EDITION=mp
