# Full Sandbox Environment Configuration
# Copy this to .env.full and fill in your paths

# Path to Stata-Tools repository (or any other repo to test)
STATA_TOOLS_PATH=../..

# Path to Stata for LINUX installation (REQUIRED)
# Store OUTSIDE your repos - this is reusable across projects
# You need the Linux version of Stata, not macOS
#
# Recommended location:
STATA_LINUX_PATH=/Users/tcopeland/stata17-linux
#
# Download from: https://www.stata.com/support/faqs/unix/install-download/
# Extract to the path above, then add your stata.lic file

# Path to Stata-MCP server (from your VS Code extension)
# Copy the src directory from the extension
STATA_MCP_PATH=/Users/tcopeland/.vscode/extensions/deepecon.stata-mcp-0.3.6/src

# Stata edition (mp, se, or be)
STATA_EDITION=mp
