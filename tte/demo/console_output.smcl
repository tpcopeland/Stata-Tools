. local coef_names: colnames `b_coef'
{txt}
{com}. local trt_idx = 0
{txt}
{com}. forvalues i = 1/`=colsof(`b_coef')' {c -(}
{txt}  2{com}.     local cname: word `i' of `coef_names'
{txt}  3{com}.     if "`cname'" != "_cons" & `trt_idx' == 0 {c -(}
{txt}  4{com}.         local trt_idx = `i'
{txt}  5{com}.     {c )-}
{txt}  6{com}. {c )-}
{txt}
{com}. local stata_coef = `b_coef'[1, `trt_idx']
{txt}
{com}. local stata_se = sqrt(`V_coef'[`trt_idx', `trt_idx'])
{txt}
{com}. local stata_ci_lo = `stata_coef' - 1.96 * `stata_se'
{txt}
{com}. local stata_ci_hi = `stata_coef' + 1.96 * `stata_se'
{txt}
{com}. local stata_p = 2 * (1 - normal(abs(`stata_coef' / `stata_se')))
{txt}
{com}. 
. noisily display as text ""
{res}{txt}

{com}. noisily display as text %20s "" %12s "Coefficient" %12s "Robust SE" %22s "95% CI" %10s "p-value"
{res}                    {txt} Coefficient   Robust SE                95% CI   p-value

{com}. noisily display as text _dup(76) "-"
{res}{txt}----------------------------------------------------------------------------

{com}. noisily display as text %20s "R TrialEmulation" ///
>     as result %12.3f -0.273 %12.3f 0.310 ///
>     as text "  [" as result %7.3f -0.880 as text ", " as result %7.3f 0.335 as text "]" ///
>     as result %10.3f 0.379
{res}    {txt}R TrialEmulation{res}      -0.273       0.310{txt}  [{res} -0.880{txt}, {res}  0.335{txt}]{res}     0.379
{txt}
{com}. noisily display as text %20s "Stata tte" ///
>     as result %12.3f `stata_coef' %12.3f `stata_se' ///
>     as text "  [" as result %7.3f `stata_ci_lo' as text ", " as result %7.3f `stata_ci_hi' as text "]" ///
>     as result %10.3f `stata_p'
{res}           {txt}Stata tte{res}      -0.282       0.313{txt}  [{res} -0.894{txt}, {res}  0.331{txt}]{res}     0.368
{txt}
{com}. noisily display as text _dup(76) "-"
{res}{txt}----------------------------------------------------------------------------

{com}. 
. log close demo
{smcl}
{com}{sf}{ul off}