{smcl}
{txt}{sf}{ul off}
{com}. 
. * =====================================================================
. * EXAMPLE 1: Basic conversion of common date formats
. * =====================================================================
. 
. noisily display as text "EXAMPLE 1: Basic date conversion"
{res}{txt}EXAMPLE 1: Basic date conversion

{com}. 
. clear
{txt}
{com}. input str25 visit_date str25 birth_date

     {txt}               visit_date                 birth_date
  1{com}. "2024-03-15"    "1985/06/21"
{txt}  2{com}. "2024/01/10"    "1990-12-01"
{txt}  3{com}. "2023-11-28"    "1978/03/14"
{txt}  4{com}. "2024-07-04"    "2001/09/30"
{txt}  5{com}. "2023-09-01"    "1995/07/15"
{txt}  6{com}. end
{txt}
{com}. 
. noisily list, clean noobs
{txt}
    {res}visit_date   birth_date {txt} 
    {res}2024-03-15   1985/06/21 {txt} 
    {res}2024/01/10   1990-12-01 {txt} 
    {res}2023-11-28   1978/03/14 {txt} 
    {res}2024-07-04   2001/09/30 {txt} 
    {res}2023-09-01   1995/07/15 {txt} 

{com}. 
. * Convert both at once — datefix auto-detects ordering
. noisily datefix visit_date birth_date
{txt}Auto-detected date format: YMD
Date variable visit_date converted to date formatted numeric variable.
       Original name retained and original visit_date dropped, given visit_date was a string; otherwise, date format applied.
Missing values: 0 before, 0 after
Auto-detected date format: YMD
Date variable birth_date converted to date formatted numeric variable.
       Original name retained and original birth_date dropped, given birth_date was a string; otherwise, date format applied.
Missing values: 0 before, 0 after

{com}. noisily list, clean noobs
{txt}
    {res}visit_date   birth_date {txt} 
    {res}2024/03/15   1985/06/21 {txt} 
    {res}2024/01/10   1990/12/01 {txt} 
    {res}2023/11/28   1978/03/14 {txt} 
    {res}2024/07/04   2001/09/30 {txt} 
    {res}2023/09/01   1995/07/15 {txt} 

{com}. 
. * =====================================================================
. * EXAMPLE 2: Explicit ordering and custom display format
. * =====================================================================
. 
. noisily display _newline
{res}

{txt}
{com}. noisily display as text "EXAMPLE 2: MDY ordering + custom format"
{res}{txt}EXAMPLE 2: MDY ordering + custom format

{com}. 
. clear
{txt}
{com}. input str20 enrollment

     {txt}          enrollment
  1{com}. "03/15/2024"
{txt}  2{com}. "01/10/2024"
{txt}  3{com}. "11/28/2023"
{txt}  4{com}. "07/04/2024"
{txt}  5{com}. "09/01/2023"
{txt}  6{com}. end
{txt}
{com}. 
. noisily list, clean noobs
{txt}
    {res}enrollment {txt} 
    {res}03/15/2024 {txt} 
    {res}01/10/2024 {txt} 
    {res}11/28/2023 {txt} 
    {res}07/04/2024 {txt} 
    {res}09/01/2023 {txt} 

{com}. 
. noisily datefix enrollment, order(MDY) df(%tdMonth_DD,_CCYY)
{txt}Date variable enrollment converted to date formatted numeric variable.
       Original name retained and original enrollment dropped, given enrollment was a string; otherwise, date format applied.
Missing values: 0 before, 0 after

{com}. noisily list, clean noobs
{txt}
    {res}        enrollment {txt} 
    {res}    March 15, 2024 {txt} 
    {res}  January 10, 2024 {txt} 
    {res} November 28, 2023 {txt} 
    {res}     July 04, 2024 {txt} 
    {res}September 01, 2023 {txt} 

{com}. 
. * =====================================================================
. * EXAMPLE 3: Two-digit years with topyear()
. * =====================================================================
. 
. noisily display _newline
{res}

{txt}
{com}. noisily display as text "EXAMPLE 3: Two-digit years"
{res}{txt}EXAMPLE 3: Two-digit years

{com}. 
. clear
{txt}
{com}. input str15 founding_date

     {txt}  founding_date
  1{com}. "15/06/89"
{txt}  2{com}. "01/03/95"
{txt}  3{com}. "22/11/78"
{txt}  4{com}. "07/08/01"
{txt}  5{com}. "30/12/65"
{txt}  6{com}. end
{txt}
{com}. 
. noisily list, clean noobs
{txt}
    {res}foundi~e {txt} 
    {res}15/06/89 {txt} 
    {res}01/03/95 {txt} 
    {res}22/11/78 {txt} 
    {res}07/08/01 {txt} 
    {res}30/12/65 {txt} 

{com}. 
. noisily datefix founding_date, order(DMY) topyear(2025)
{txt}Date variable founding_date converted to date formatted numeric variable.
       Original name retained and original founding_date dropped, given founding_date was a string; otherwise, date format applied.
Missing values: 0 before, 0 after

{com}. noisily list, clean noobs
{txt}
    {res}founding~e {txt} 
    {res}1989/06/15 {txt} 
    {res}1995/03/01 {txt} 
    {res}1978/11/22 {txt} 
    {res}2001/08/07 {txt} 
    {res}1965/12/30 {txt} 

{com}. 
. * =====================================================================
. * EXAMPLE 4: newvar() to preserve original
. * =====================================================================
. 
. noisily display _newline
{res}

{txt}
{com}. noisily display as text "EXAMPLE 4: Creating new variable with newvar()"
{res}{txt}EXAMPLE 4: Creating new variable with newvar()

{com}. 
. clear
{txt}
{com}. input str20 raw_date

     {txt}            raw_date
  1{com}. "2024-03-15"
{txt}  2{com}. "2024-01-10"
{txt}  3{com}. "2023-11-28"
{txt}  4{com}. end
{txt}
{com}. 
. noisily list, clean noobs
{txt}
    {res}  raw_date {txt} 
    {res}2024-03-15 {txt} 
    {res}2024-01-10 {txt} 
    {res}2023-11-28 {txt} 

{com}. 
. noisily datefix raw_date, newvar(clean_date) order(YMD)
{txt}Date variable raw_date converted to date formatted numeric variable: clean_date.
       Original raw_date retained.
Missing values: 0 before, 0 after

{com}. noisily list, clean noobs
{txt}
    {res}  raw_date   clean_date {txt} 
    {res}2024-03-15   2024/03/15 {txt} 
    {res}2024-01-10   2024/01/10 {txt} 
    {res}2023-11-28   2023/11/28 {txt} 

{com}. 
. log close demo
{smcl}
{com}{sf}{ul off}