. do /home/tpcopeland/Stata-Dev/_devkit/_validation/cross_validation/tte_vs_r/0
> 2_stata_crossval.do 

. * Cross-Validation: Stata tte vs R TrialEmulation
. * Runs matching analyses on trial_example data exported from R
. * Compares coefficients, SEs, and predictions
. *
. * Prerequisites: Run 01_r_analysis.R first to generate data and R results.
. 
. version 16.0

. set varabbrev off

. set more off

. clear all

. set seed 12345

. 
. * =========================================================================
. * SETUP
. * =========================================================================
. 
. local basedir "_devkit/_validation/cross_validation/tte_vs_r"

. local datadir "`basedir'/data"

. local rdir    "`basedir'/r_results"

. 
. * Uninstall any installed version to ensure local .ado files are used
. capture ado uninstall tte

. 
. * Add local tte package to adopath
. adopath ++ "tte"
  [1]              "tte"
  [2]  (BASE)      "/usr/local/stata17/ado/base/"
  [3]  (SITE)      "/usr/local/ado/"
  [4]              "."
  [5]  (PERSONAL)  "~/ado/personal/"
  [6]  (PLUS)      "~/ado/plus/"
  [7]  (OLDPLACE)  "~/ado/"

. 
. * Verify R results exist
. capture confirm file "`rdir'/config1_itt_coefs.csv"

. if _rc != 0 {
.     display as error "R results not found. Run 01_r_analysis.R first."
R results not found. Run 01_r_analysis.R first.
.     exit 601
r(601);
. }
r(601);

end of do-file
