. * =====================================================================
. * BUILD COMBINED RESULTS DATASET
. * =====================================================================
. 
. clear

. local total_rows = 9 + 7 + 2

. set obs `total_rows'
Number of observations (_N) was 0, now 18.

. 
. gen str20 dataset = ""
(18 missing values generated)

. gen str20 treatment = ""
(18 missing values generated)

. gen double r_value = .
(18 missing values generated)

. gen double stata_value = .
(18 missing values generated)

. gen double diff = .
(18 missing values generated)

. gen str6 status = ""
(18 missing values generated)

. 
. local row = 0

. 
. * Senn treatments
. foreach t of local senn_treatments {
  2.     local ++row
  3.     quietly replace dataset = "Senn 2013" in `row'
  4.     quietly replace treatment = "`t'" in `row'
  5.     quietly replace r_value = `r_s_`t'' in `row'
  6.     quietly replace stata_value = `s_s_`t'' in `row'
  7.     quietly replace diff = abs(`r_s_`t'' - `s_s_`t'') in `row'
  8. 
.     local d = abs(`r_s_`t'' - `s_s_`t'')
  9.     if `d' < `tol' {
 10.         quietly replace status = "PASS" in `row'
 11.         local ++n_pass
 12.     }
 13.     else if `d' < 0.10 {
 14.         quietly replace status = "NOTE*" in `row'
 15.         local ++n_note
 16.     }
 17.     else {
 18.         quietly replace status = "FAIL" in `row'
 19.         local ++n_fail
 20.     }
 21. }

. 
. * Senn tau2
. local ++row

. quietly replace dataset = "Senn 2013" in `row'

. quietly replace treatment = "tau2" in `row'

. quietly replace r_value = `r_s_tau2' in `row'

. quietly replace stata_value = `senn_tau2' in `row'

. quietly replace diff = abs(`r_s_tau2' - `senn_tau2') in `row'

. quietly replace status = "INFO" in `row'

. 
. * Dogliotti treatments
. foreach t of local dog_treatments {
  2.     local ++row
  3.     quietly replace dataset = "Dogliotti 2014" in `row'
  4.     quietly replace treatment = "`t'" in `row'
  5.     quietly replace r_value = `r_d_`t'' in `row'
  6.     quietly replace stata_value = `s_d_`t'' in `row'
  7.     quietly replace diff = abs(`r_d_`t'' - `s_d_`t'') in `row'
  8. 
.     local d = abs(`r_d_`t'' - `s_d_`t'')
  9.     if `d' < `tol' {
 10.         quietly replace status = "PASS" in `row'
 11.         local ++n_pass
 12.     }
 13.     else {
 14.         quietly replace status = "FAIL" in `row'
 15.         local ++n_fail
 16.     }
 17. }

. 
. * Dogliotti tau2
