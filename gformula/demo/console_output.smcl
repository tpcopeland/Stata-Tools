{smcl}
{txt}{sf}{ul off}
{com}. 
. * =====================================================================
. * EXAMPLE 1: Mediation with binary exposure (OBE)
. * =====================================================================
. * Scenario: Does smoking (x) affect lung function (y),
. *   and how much is mediated through inflammation (m)?
. *   Adjusted for age (c).
. 
. noisily display as text "EXAMPLE 1: Binary exposure mediation (OBE)"
{res}{txt}EXAMPLE 1: Binary exposure mediation (OBE)

{com}. 
. clear
{txt}
{com}. set seed 12345
{txt}
{com}. set obs 1000
{txt}{p}
Number of observations ({bf:_N}) was 0,
now 1,000.
{p_end}

{com}. 
. * Generate data with known causal structure
. gen double c = rnormal(50, 10)
{txt}
{com}. gen double x = rbinomial(1, invlogit(-2 + 0.02 * c))
{txt}
{com}. gen double m = rbinomial(1, invlogit(-1 + 0.8 * x + 0.01 * c))
{txt}
{com}. gen double y = rbinomial(1, invlogit(-3 + 0.5 * m + 0.3 * x + 0.02 * c))
{txt}
{com}. 
. noisily gformula y m x c, outcome(y) mediation obe ///
>     exposure(x) mediator(m) ///
>     commands(m: logit, y: logit) ///
>     equations(m: x c, y: m x c) ///
>     base_confs(c) sim(500) samples(50) seed(42)

{txt}G-computation procedure using Monte Carlo simulation: mediation


   Outcome variable: {res}y
{txt}   Exposure variable(s): {res}x
{txt}   Mediator variable(s): {res}m
{txt}   Size of MC sample: {res}500
{txt}   No. of bootstrap samples: {res}50


{txt}   A summary of the specified parametric models:

   (for simulation under different interventions)

      Variable {c |} Command {c |} Prediction equation
   {hline 12}{c +}{hline 9}{c +}{hline 55}
             m {c |} logit   {c |}  x c
             y {c |} logit   {c |}  m x c
   {hline 12}{c BT}{hline 9}{c BT}{hline 55}


