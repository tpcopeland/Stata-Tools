{com}. 
. * =====================================================================
. * EXAMPLE 2: Mediation with categorical exposure (OCE)
. * =====================================================================
. * Scenario: Physical activity level (0=none, 1=moderate, 2=high)
. *   affecting depression (y), mediated through sleep quality (m).
. 
. noisily display _newline
{res}

{txt}
{com}. noisily display as text "EXAMPLE 2: Categorical exposure mediation (OCE)"
{res}{txt}EXAMPLE 2: Categorical exposure mediation (OCE)

{com}. 
. clear
{txt}
{com}. set seed 54321
{txt}
{com}. set obs 1000
{txt}{p}
Number of observations ({bf:_N}) was 0,
now 1,000.
{p_end}

{com}. 
. gen double c = rnormal()
{txt}
{com}. gen double x = floor(runiform() * 3)
{txt}
{com}. gen double m = rbinomial(1, invlogit(-0.5 + 0.3 * x + 0.2 * c))
{txt}
{com}. gen double y = rbinomial(1, invlogit(-1 + 0.4 * m - 0.2 * x + 0.1 * c))
{txt}
{com}. 
. noisily gformula y m x c, outcome(y) mediation oce ///
>     exposure(x) mediator(m) ///
>     commands(m: logit, y: logit) ///
>     equations(m: x c, y: m x c) ///
>     base_confs(c) sim(500) samples(50) seed(42)

{txt}G-computation procedure using Monte Carlo simulation: mediation

{err}Warning: Option baseline() has not been specified, and therefore the baseline will be assumed to be {res}0{err}.

