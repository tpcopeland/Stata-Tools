{smcl}
{txt}{sf}{ul off}
{com}. 
. * =====================================================================
. * EXAMPLE 1: Default format (YYYY_MM_DD)
. * =====================================================================
. 
. noisily display as text "EXAMPLE 1: Default format"
{res}{txt}EXAMPLE 1: Default format

{com}. 
. noisily today
{res}{bf:$today} set to: {com}2026_02_28
{res}{bf:$today_time} set to: {com}2026_02_28 23:16:35
{txt}
{com}. noisily display `"  $$today = $today"'
{res}  $2026_02_28 = 2026_02_28
{txt}
{com}. noisily display `"  $$today_time = $today_time"'
{res}  $2026_02_28 23:16:35 = 2026_02_28 23:16:35
{txt}
{com}. 
. * =====================================================================
. * EXAMPLE 2: European format (DD Mon YYYY)
. * =====================================================================
. 
. noisily display _newline
{res}

{txt}
{com}. noisily display as text "EXAMPLE 2: European format (dmony)"
{res}{txt}EXAMPLE 2: European format (dmony)

{com}. 
. noisily today, df(dmony)
{res}{bf:$today} set to: {com}28 Feb 2026
{res}{bf:$today_time} set to: {com}28 Feb 2026 23:16:35
{txt}
{com}. noisily display `"  $$today = $today"'
{res}  $28 Feb 2026 = 28 Feb 2026
{txt}
{com}. noisily display `"  $$today_time = $today_time"'
{res}  $28 Feb 2026 23:16:35 = 28 Feb 2026 23:16:35
{txt}
{com}. 
. * =====================================================================
. * EXAMPLE 3: US format (MM/DD/YYYY)
. * =====================================================================
. 
. noisily display _newline
{res}

{txt}
{com}. noisily display as text "EXAMPLE 3: US format (mdy)"
{res}{txt}EXAMPLE 3: US format (mdy)

{com}. 
. noisily today, df(mdy)
{res}{bf:$today} set to: {com}02/28/2026
{res}{bf:$today_time} set to: {com}02/28/2026 23:16:35
{txt}
{com}. noisily display `"  $$today = $today"'
{res}  $02/28/2026 = 02/28/2026
{txt}
{com}. noisily display `"  $$today_time = $today_time"'
{res}  $02/28/2026 23:16:35 = 02/28/2026 23:16:35
{txt}
{com}. 
. * =====================================================================
. * EXAMPLE 4: Hours and minutes only, custom separator
. * =====================================================================
. 
. noisily display _newline
{res}

{txt}
{com}. noisily display as text "EXAMPLE 4: Hours:minutes only, dot separator"
{res}{txt}EXAMPLE 4: Hours:minutes only, dot separator

{com}. 
. noisily today, hm tsep(.)
{res}{bf:$today} set to: {com}2026_02_28
{res}{bf:$today_time} set to: {com}2026_02_28 23.16
{txt}
{com}. noisily display `"  $$today_time = $today_time"'
{res}  $2026_02_28 23.16 = 2026_02_28 23.16
{txt}
{com}. 
. * =====================================================================
. * EXAMPLE 5: Using $today in file naming
. * =====================================================================
. 
. noisily display _newline
{res}

{txt}
{com}. noisily display as text "EXAMPLE 5: Using $$today for file naming"
{res}{txt}EXAMPLE 5: Using $2026_02_28 for file naming

{com}. 
. today
{res}{bf:$today} set to: {com}2026_02_28
{res}{bf:$today_time} set to: {com}2026_02_28 23:16:35
{txt}
{com}. noisily display `"  Log file:    analysis_$today.log"'
{res}  Log file:    analysis_2026_02_28.log
{txt}
{com}. noisily display `"  Export file:  results_$today.csv"'
{res}  Export file:  results_2026_02_28.csv
{txt}
{com}. noisily display `"  Timestamp:   $today_time"'
{res}  Timestamp:   2026_02_28 23:16:35
{txt}
{com}. 
. log close demo
{smcl}
{com}{sf}{ul off}